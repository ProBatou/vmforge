############################################
# Homelab Deploy - Example Configuration
############################################

##########################
# Required Credentials   #
##########################
# Proxmox API token (Datacenter -> Permissions -> API Tokens)
PROXMOX_TOKEN_ID="root@pam!deploy"
PROXMOX_TOKEN_SECRET="replace-me"

# OPNsense (Kea DHCP API)
OPNSENSE_HOST="10.0.0.1"
OPNSENSE_API_KEY="replace-me"
OPNSENSE_API_SECRET="replace-me"

##########################
# Proxmox (required)     #
##########################
PROXMOX_HOST="pve.example.com:8006"
PROXMOX_NODE="pve"
PROXMOX_TEMPLATE_ID="280"
PROXMOX_STORAGE="local-lvm"

# VMID allocation strategy:
# nextid       -> ask Proxmox for cluster next free ID
# range_first  -> first free ID in [PROXMOX_VMID_RANGE_START, PROXMOX_VMID_RANGE_END]
# range_random -> random free ID in [PROXMOX_VMID_RANGE_START, PROXMOX_VMID_RANGE_END]
# manual       -> fixed ID from PROXMOX_VMID
PROXMOX_VMID_POLICY="nextid"
PROXMOX_VMID_RANGE_START="200"
PROXMOX_VMID_RANGE_END="299"
# PROXMOX_VMID="212"  # used only when PROXMOX_VMID_POLICY=manual

############################################
# SSH to Cloned VMs                        #
############################################
SSH_KEY_FILE="$HOME/.ssh/deploy_automation"
SSH_USER="root"

##########################
# Execution mode         #
##########################
# full      = provisioning + optional proxy
# provision = provisioning only
# proxy     = proxy only
DEPLOY_FLOW="full"

##########################
# Reverse Proxy          #
##########################
# Options: zoraxy_api | none
PROXY_PROVIDER="none"
ZORAXY_API_BASE="http://zoraxy.example.com:8400"
ZORAXY_USERNAME=""
ZORAXY_PASSWORD=""

# Optional proxy tuning
# PROXY_UPSTREAM_PORT="80"
# PROXY_UPSTREAM_TLS="false"
# PROXY_AUTO_DETECT_PORT="true"
# PROXY_PORT_CANDIDATES="80,8080,3000,3001,5000,5173,8000,8081,9000,8443,443"
# PROXY_PORT_PROBE_TIMEOUT="2"
# PROXY_AUTO_PORT_STRATEGY="first"   # first|strict

##########################
# Optional Step Control  #
##########################
# auto: run only when provider != none
# 1/true/on/yes: force run
# 0/false/off/no: force skip
ENABLE_PROXY="auto"

##########################
# Timeouts               #
##########################
# Max seconds to wait for SSH to become reachable after VM boot (default: 300)
# SSH_WAIT_TIMEOUT="300"
# Max seconds to wait for cloud-init completion marker (default: 120)
# CLOUD_INIT_TIMEOUT="120"
